<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | Triumph Tower</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <span class="navbar-brand fw-bold">Triumph Tower Admin</span>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card p-3 shadow-sm border-0">
                    <small class="text-muted">Total Dues Collected</small>
                    <h3 class="fw-bold text-primary">₹4.2L</h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3 shadow-sm border-0">
                    <small class="text-muted">Active Guests</small>
                    <h3 class="fw-bold text-warning">12</h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3 shadow-sm border-0">
                    <small class="text-muted">Waste Processed</small>
                    <h3 class="fw-bold text-success">375kg</h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3 shadow-sm border-0">
                    <small class="text-muted">Complaints Open</small>
                    <h3 class="fw-bold text-danger">2</h3>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-8">
                <div class="card shadow-sm border-0 p-4">
                    <h5 class="fw-bold mb-4">Visitor Approval Queue</h5>
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Resident</th>
                                <th>Guest</th>
                                <th>Requested At</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (requests.length > 0) { %>
                                <% requests.forEach(request => { %>
                                    <tr class="align-middle">
                                        <td><strong><%= request.residentName %></strong> (<%= request.flatNumber %>)</td>
                                        <td><%= request.visitorName %></td>
                                        <td><%= new Date(request.createdAt).toLocaleTimeString() %></td>
                                        <td>
                                            <span class="badge <%= request.status === 'Approved' ? 'bg-success' : 'bg-warning' %>">
                                                <%= request.status %>
                                            </span>
                                        </td>
                                        <td>
                                            <% if (request.status === 'Pending') { %>
                                                <button onclick="updateStatus('<%= request._id %>', 'Approved')" class="btn btn-sm btn-success">Approve</button>
                                                <button onclick="updateStatus('<%= request._id %>', 'Denied')" class="btn btn-sm btn-outline-danger">Deny</button>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="5" class="text-center py-4 text-muted">No pending visitor requests.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm border-0 p-4">
                    <h5 class="fw-bold mb-3">Broadcast Notice</h5>
                    <textarea class="form-control mb-3" rows="3" placeholder="Type notice for all residents..."></textarea>
                    <button class="btn btn-primary w-100">Send Announcement</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        async function updateStatus(id, newStatus) {
            const response = await fetch('/api/visitor/update-status', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id, status: newStatus })
            });
            if (response.ok) location.reload();
        }
    </script>
</body>
</html>
