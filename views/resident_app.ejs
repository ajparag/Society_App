<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resident Portal | Triumph Tower</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .action-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; margin-top: 20px; }
        .qr-modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 1000; justify-content: center; align-items: center; flex-direction: column; color: white; }
        #qrImage { width: 250px; height: 250px; background: white; border-radius: 15px; padding: 10px; }
    </style>
</head>
<body class="p-3">

    <div class="container-sm">
        <header class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="fw-bold mb-0">Triumph Tower</h4>
                <p class="text-muted small mb-0">Flat A-502 | Parag Agarwal</p>
            </div>
            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">PA</div>
        </header>

        <div class="card app-card mb-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <small class="text-muted d-block">Maintenance Dues</small>
                    <h4 class="mb-0 text-success">Paid</h4>
                </div>
                <button class="btn btn-sm btn-outline-primary">View Ledger</button>
            </div>
        </div>

        <div class="action-grid">
            <div class="card app-card text-center py-3" onclick="showVisitorForm()">
                <div class="fs-2 mb-1">🛡️</div>
                <span class="small fw-bold">Guest Pass</span>
            </div>
            <div class="card app-card text-center py-3">
                <div class="fs-2 mb-1">🧼</div>
                <span class="small fw-bold">Daily Help</span>
            </div>
            <div class="card app-card text-center py-3">
                <div class="fs-2 mb-1">🎾</div>
                <span class="small fw-bold">Amenities</span>
            </div>
            <div class="card app-card text-center py-3">
                <div class="fs-2 mb-1">📢</div>
                <span class="small fw-bold">Notices</span>
            </div>
        </div>

        <div class="card app-card mt-4">
            <h6 class="fw-bold mb-2">Society Green Score</h6>
            <div class="progress" style="height: 10px; border-radius: 5px;">
                <div class="progress-bar bg-success" role="progressbar" style="width: 75%"></div>
            </div>
            <p class="small text-muted mt-2 mb-0">375kg waste processed this month. <b>Great job!</b></p>
        </div>

        <div id="visitorForm" class="mt-4 card app-card" style="display: none;">
            <h6 class="fw-bold mb-3">Pre-Authorize Guest</h6>
            <input type="text" id="visitorName" class="form-control mb-2" placeholder="Guest Name">
            <button onclick="generatePass()" class="btn btn-primary-modern w-100">Generate Pass</button>
        </div>
    </div>

    <div id="qrModal" class="qr-modal" onclick="this.style.display='none'">
        <img id="qrImage" src="" alt="QR Code">
        <h5 class="mt-3 fw-bold">Guest Entry Pass</h5>
        <p>Tap anywhere to close</p
